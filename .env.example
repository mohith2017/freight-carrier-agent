DATASET_DIR=../goodlane-interview-dataset

# Primary store. Leave unset to default to local SQLite (data/freight.db).
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Local SQLite backup/dev path (always written, even when DATABASE_URL is set).
SQLITE_PATH=data/freight.db

OPENAI_API_KEY=

AGENT_MODEL=gpt-5.5
EXTRACTION_MODEL=gpt-5.4-mini
TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
